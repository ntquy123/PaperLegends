FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    lib32gcc-s1 \
    libstdc++6 \
    libglu1-mesa \
    libxcursor1 \
    libxrandr2 \
    libxinerama1 \
    libxi6 \
    libnss3 \
    libasound2 \
    libglib2.0-0 \
    libgconf-2-4 \
  && rm -rf /var/lib/apt/lists/*

ENV HOME=/root \
    XDG_CONFIG_HOME=/root/.config

WORKDIR /home/deploy/server

ARG SERVER_EXECUTABLE=PaperLegendServer.x86_64

# Copy the dedicated server build produced by Unity. Expected contents:
# - PaperLegendServer.x86_64 or the executable passed by SERVER_EXECUTABLE
# - the matching *_Data/ folder
# - any other files generated by the headless build
COPY docker/unity-server/build/ /home/deploy/server/

RUN mkdir -p /root/.config/unity3d/GameNhaLam/ServerGame \
  && chmod +x "/home/deploy/server/${SERVER_EXECUTABLE}" \
  && if [ "${SERVER_EXECUTABLE}" != "PaperLegendServer.x86_64" ]; then \
       ln -sf "${SERVER_EXECUTABLE}" /home/deploy/server/PaperLegendServer.x86_64; \
     fi

EXPOSE 27015

ENTRYPOINT ["./PaperLegendServer.x86_64"]
CMD ["-batchmode", "-nographics", "-dedicatedServer", "1", "-logfile", "-"]
