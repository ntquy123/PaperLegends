# Unity Addressables build output only.
# Keep source assets such as Assets/AddressableAsset/** tracked.
**/ServerData/
**/Assets/StreamingAssets/aa/
**/Assets/StreamingAssets/aa.meta
**/Assets/AddressableAssetsData/*/*.bin*
**/Library/com.unity.addressables/

# Local databases / generated runtime data
*.db
*.sqlite
*.sqlite3

# Node / web API generated files
WEB_SERVER/node_modules/
WEB_SERVER/dist/
WEB_SERVER/generated/
WEB_SERVER/.turbo/
WEB_SERVER/.cache/

# Secrets and private deployment data
**/.env
**/.env.*
!**/.env.example
!**/.env.sample
WEB_SERVER/ssl/
*.pem
*.key
*.crt
*.p12

# Docker / deployment build outputs
WEB_SERVER/docker/unity-server/build/*
!WEB_SERVER/docker/unity-server/build/.gitkeep
WEB_SERVER/addressables/

# Archives and backups
*.zip
*.rar
*.7z
*.bak
*.backup
